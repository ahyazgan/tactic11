# Ortam — dev | staging | prod
# `prod` modunda boot'ta validate_for_production() çalışır: zorunlu secret'lar
# eksikse ConfigError fırlatılır (sessiz unsafe boot olmasın).
APP_ENV=dev

# API-Football (api-sports.io) — https://www.api-football.com/
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# PostgreSQL (Supabase veya yerel) — prod modunda SQLite kabul edilmez
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# Anthropic — opsiyonel (boş ise Claude stub mod)
ANTHROPIC_API_KEY=

# Kota koruması (core/usage)
API_FOOTBALL_DAILY_LIMIT=100
API_FOOTBALL_MONTHLY_LIMIT=2000
ANTHROPIC_DAILY_TOKEN_LIMIT=200000

# Eski X-API-Key tabanlı auth — Ufuk 1 ile JWT geldi, ama eski entegrasyonlar
# için bu key set'liyse hâlâ kabul edilir (default tenant admin'e map edilir).
# Yeni deploy'lar JWT_SECRET_KEY ile çalışsın.
API_AUTH_KEY=

# Multi-tenant JWT auth (Ufuk 1) — production'da ZORUNLU
# Üretmek için: `python -c "import secrets; print(secrets.token_hex(32))"`
JWT_SECRET_KEY=
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# Eski X-API-Key'i JWT olmadan da kabul etmek için (sadece backward-compat).
# Bu değer set'liyse `X-API-Key: <değer>` → default tenant + admin user.
BACKWARD_COMPAT_API_KEY=

# Geliştirme/test
# true ise adapter API yerine tests/fixtures'tan okur. Prod'da false olmalı.
USE_FIXTURES=false

# log seviyesi: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# log format: text (default, okunabilir) | json (production aggregator için)
LOG_FORMAT=text

# Production hardening
# Dakika başına izinli istek (API key veya IP başına; /health bypass'lı)
RATE_LIMIT_PER_MINUTE=120

# Notifications (Faz 5 #19) — kanal başına env'ler set'liyse gerçek mesaj,
# boşsa kanal stub modda kalır (system çalışır, log'da "STUB" görünür).

# Telegram Bot: @BotFather'dan token al; chat_id için bot'a /start yazıp
# https://api.telegram.org/bot{TOKEN}/getUpdates ile chat.id'yi gör.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WhatsApp via Twilio: console.twilio.com'da Sandbox abone ol.
# WHATSAPP_FROM = Twilio sender (örn: whatsapp:+14155238886)
# WHATSAPP_TO   = doğrulanmış alıcı (örn: whatsapp:+90555...)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
WHATSAPP_FROM=
WHATSAPP_TO=

# E-posta (SMTP) — stdlib smtplib. SMTP_HOST/SMTP_FROM/SMTP_TO boşsa stub mod.
# Gmail için: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, uygulama-şifresi kullan.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true

# Redis cache backend (opsiyonel). Boşsa DB-destekli cache kullanılır.
# Üretimde ölçek için: REDIS_URL=redis://localhost:6379/0
REDIS_URL=
