# Ortam — dev | staging | prod
# `prod` modunda boot'ta validate_for_production() çalışır: zorunlu secret'lar
# eksikse ConfigError fırlatılır (sessiz unsafe boot olmasın).
APP_ENV=dev

# API-Football (api-sports.io) — https://www.api-football.com/
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# PostgreSQL (Supabase veya yerel) — prod modunda SQLite kabul edilmez
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# Anthropic — opsiyonel (boş ise Claude stub mod)
ANTHROPIC_API_KEY=

# Kota koruması (core/usage)
API_FOOTBALL_DAILY_LIMIT=100
API_FOOTBALL_MONTHLY_LIMIT=2000
ANTHROPIC_DAILY_TOKEN_LIMIT=200000

# API erişim anahtarı. Boş ise auth devre dışı (sadece dev için).
# İstemciler `X-API-Key: <değer>` header'ında gönderir. Prod'da ZORUNLU.
API_AUTH_KEY=

# Geliştirme/test
# true ise adapter API yerine tests/fixtures'tan okur. Prod'da false olmalı.
USE_FIXTURES=false

# log seviyesi: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# log format: text (default, okunabilir) | json (production aggregator için)
LOG_FORMAT=text

# Production hardening
# Dakika başına izinli istek (API key veya IP başına; /health bypass'lı)
RATE_LIMIT_PER_MINUTE=120
