# API-Football (api-sports.io) — https://www.api-football.com/
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# PostgreSQL (Supabase veya yerel)
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# Anthropic (Faz 3'te kullanılacak — şimdi boş bırakılabilir)
ANTHROPIC_API_KEY=

# Kota koruması (core/usage)
API_FOOTBALL_DAILY_LIMIT=100
API_FOOTBALL_MONTHLY_LIMIT=2000
ANTHROPIC_DAILY_TOKEN_LIMIT=200000

# API erişim anahtarı. Boş ise auth devre dışı (sadece dev için).
# İstemciler `X-API-Key: <değer>` header'ında gönderir.
API_AUTH_KEY=

# Geliştirme/test
# true ise adapter API yerine tests/fixtures'tan okur (Faz 1, madde 9)
USE_FIXTURES=false

# log seviyesi: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
